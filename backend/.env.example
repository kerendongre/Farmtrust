# Environment
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=farmtrust
DB_PASSWORD=farmtrust_secure_password
DB_NAME=farmtrust_db
DATABASE_URL=postgresql://farmtrust:farmtrust_secure_password@localhost:5432/farmtrust_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=your_firebase_database_url

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# QR Code
QR_CODE_ENCRYPTION_KEY=your_encryption_key_for_qr_codes
